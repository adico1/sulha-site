# Claude Code Hooks Configuration
# להגבלת Claude מפעולות ישירות

# הגדרה ב-Claude Code settings:
# Settings → Hooks → Pre-tool hooks

# Hook לפני Write tool:
# - בדוק אם הכתיבה היא ל-bus.queue בלבד
# - דחה כל כתיבה אחרת

pre_write_hook: |
  #!/bin/bash
  # בדוק אם הכתיבה מותרת
  TARGET="$1"

  # מותר לכתוב רק ל-bus
  if [[ "$TARGET" == *"bus.queue"* ]]; then
    exit 0  # מותר
  fi

  # מותר לקרוא מכל מקום
  # אבל לכתוב - רק ל-bus

  echo "אסור: Claude לא מורשה לכתוב ישירות"
  echo "השתמש ב-bus: חכמה/bus.queue"
  exit 1  # אסור

# Hook לפני Bash tool:
pre_bash_hook: |
  #!/bin/bash
  # בדוק אם הפקודה מותרת
  CMD="$1"

  # מותר להריץ רק אברם.py
  if [[ "$CMD" == *"אברם.py"* ]]; then
    exit 0  # מותר
  fi

  # מותר להריץ יה.py (CLI)
  if [[ "$CMD" == *"יה.py"* ]]; then
    exit 0  # מותר
  fi

  # מותר ls, cat לקריאה
  if [[ "$CMD" == "ls"* ]] || [[ "$CMD" == "cat"* ]]; then
    exit 0  # מותר
  fi

  echo "אסור: Claude לא מורשה להריץ ישירות"
  echo "השתמש ב-אברם.py או יה.py"
  exit 1  # אסור

# הזרימה הנכונה:
# 1. Claude כותב ל-bus.queue
# 2. אדם מריץ: python3 אברם.py
# 3. אברם קורא מ-bus ומבצע
# 4. Claude קורא תוצאה מ-bus
