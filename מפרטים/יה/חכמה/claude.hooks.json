{
  "hooks": {
    "preToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/adicohen/work/games/מערכת/י/מפרטים/יה/חכמה/blom.py check_write \"$FILE_PATH\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/adicohen/work/games/מערכת/י/מפרטים/יה/חכמה/blom.py check_bash \"$COMMAND\""
          }
        ]
      }
    ]
  },

  "_comment": "הגדרות hooks לאכיפת איסורי כיוון Claude",

  "_claude_role": {
    "name": "רוח מרוח חי העולמים",
    "type": "מאתחל",
    "allowed": [
      "Read - קריאת קבצים",
      "Write bus.queue - כתיבה ל-bus בלבד",
      "Bash יה.py - הרצת CLI",
      "Bash אברם.py - הרצת מבצע"
    ],
    "forbidden": [
      "Write * - יצירת/עריכת קבצים",
      "Bash ממיר.*.py - הרצת ממירים ישירות",
      "Bash python3 * - הרצה ישירה"
    ]
  },

  "_avram_role": {
    "name": "אברם → אברהם",
    "type": "מבצע",
    "responsibilities": [
      "קריאה מ-bus.queue",
      "הרצת ממירים",
      "כתיבת קבצים",
      "רישום ל-ledger"
    ]
  },

  "_flow": [
    "1. אדם → Claude: בקשה",
    "2. Claude → bus.queue: הודעה מפורמטת",
    "3. אדם → אברם.py: הרצה",
    "4. אברם → bus.queue: קריאה",
    "5. אברם → ממיר: הפעלה",
    "6. ממיר → קבצים: פעולה",
    "7. אברם → ledger: רישום",
    "8. Claude → ledger: קריאת תוצאה",
    "9. Claude → אדם: דיווח"
  ]
}
