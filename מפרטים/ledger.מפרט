הגדרות #
ledger:
  שם מין:
    ספר
  פעולה:
    רישום
  משפחה:
    אחסון
  schema:
    less

book:
  מכיל:
    entries
  כל entry:
    3 שורות אופקיות
  קישור:
    bid

row_1:
  שם:
    hardware
  ציר:
    עולם
  מכיל:
    - bid
    - l (location)
    - n (name)
    - e (extension)
    - p (parent)
  תבנית:
    bid:N|l:<path>|n:<name>|e:<ext>|p:<parent>

row_2:
  שם:
    interface
  ציר:
    שנה/זמן
  מכיל:
    - bid
    - size
    - created
    - modified
  תבנית:
    bid:N|size:<bytes>|created:<timestamp>|modified:<timestamp>

row_3:
  שם:
    content
  ציר:
    נפש
  מכיל:
    - bid
    - crystallized
    - content
  תבנית:
    bid:N|crystallized:<bool>|content:<escaped>

איסורים #
- no json
- no yaml
- pipe delimited only
- 3 rows per entry
- bid links rows
