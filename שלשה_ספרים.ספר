    document.getElementById('page-' + page).classList.add('visible');
    const navEl = document.getElementById('nav-' + page);
    if (navEl) navEl.classList.add('active');

    // רישום צפייה
    const areaMap = { 'hutz': 'hutz', 'pnim': 'pnim', 'pnim-pnim': 'liba' };
    if (areaMap[page]) addView(areaMap[page]);

    // עדכון צפיות אם בפנים פנים
    if (page === 'pnim-pnim') updateViewsDisplay();
}

function updateViewsDisplay() {
    const v = getViews();
    document.getElementById('views-liba').textContent = v.liba || 0;
    document.getElementById('views-pnim').textContent = v.pnim || 0;
    document.getElementById('views-hutz').textContent = v.hutz || 0;
}

function updateUI() {
    const navPnimPnim = document.getElementById('nav-pnim-pnim');
    const userArea = document.getElementById('user-area');

    if (currentUser) {
        navPnimPnim.style.display = 'inline';
        userArea.innerHTML = `<a style="color:#e8d9b0; margin-inline-start:16px;">${currentUser}</a> <button class="logout-btn" onclick="logout()">יציאה</button>`;
    } else {
        navPnimPnim.style.display = 'none';
        userArea.innerHTML = '';
    }
}

// --- הרשמה / התחברות ---
function toggleAuthMode() {
    isRegisterMode = !isRegisterMode;
    document.getElementById('auth-title').textContent = isRegisterMode ? 'הרשמה' : 'התחברות';
    document.getElementById('auth-action-text').textContent = isRegisterMode ? 'הירשם' : 'התחבר';
    document.getElementById('auth-toggle').textContent = isRegisterMode ? 'יש לך חשבון? התחבר' : 'אין לך חשבון? הירשם';
    document.getElementById('auth-message').innerHTML = '';
}

function doAuth() {
    const username = document.getElementById('auth-username').value.trim();
    const password = document.getElementById('auth-password').value;
    const msgEl = document.getElementById('auth-message');

    if (!username || !password) {
        msgEl.innerHTML = '<div class="error">נא למלא שם משתמש וסיסמה</div>';
        return;
    }

    const users = getUsers();

    if (isRegisterMode) {
        if (users[username]) {
            msgEl.innerHTML = '<div class="error">שם משתמש תפוס</div>';
            return;
        }
        users[username] = password;
        saveUsers(users);
        currentUser = username;
        localStorage.setItem('sulha_user', JSON.stringify(currentUser));
        updateUI();
        navigate('pnim-pnim');
    } else {
        if (!users[username] || users[username] !== password) {
            msgEl.innerHTML = '<div class="error">שם משתמש או סיסמה שגויים</div>';
            return;
        }
        currentUser = username;
        localStorage.setItem('sulha_user', JSON.stringify(currentUser));
        updateUI();
        navigate('pnim-pnim');
    }
}

function logout() {
    currentUser = null;
    localStorage.removeItem('sulha_user');
    updateUI();
    navigate('hutz');
}

// --- אתחול ---
updateUI();
addView('hutz'); // צפייה ראשונה בחוץ
</script>

