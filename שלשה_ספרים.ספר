            <h3>שלשה ספרים</h3>
            <div id="סיכום-ספרים" style="font-size:0.8em; color:#888;"></div>
        </div>

        <div class="צפיות">
            <div class="צפיות-כותרת">
                <span id="צפיות-כותרת-טקסט">ליבה · פנים · חוץ</span>
                <span id="צפיות-עדכון" style="font-size:0.8em; color:#666;"></span>
            </div>
            <div class="צפיות-תוכן" id="צפיות-תוכן">
                <div class="טוען">מתחבר אל הבמה...</div>
            </div>
            <div class="צפיות-רגל">
