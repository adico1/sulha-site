    return JSON.parse(localStorage.getItem('sulha_views') || '{"liba":0,"pnim":0,"hutz":0}');
}
function addView(area) {
    const v = getViews();
    v[area] = (v[area] || 0) + 1;
    localStorage.setItem('sulha_views', JSON.stringify(v));
}
function getUsers() {
    return JSON.parse(localStorage.getItem('sulha_users') || '{}');
}
function saveUsers(users) {
    localStorage.setItem('sulha_users', JSON.stringify(users));
}

// --- ניווט ---
function navigate(page) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('visible'));
    document.querySelectorAll('nav .links a').forEach(a => a.classList.remove('active'));

    if (page === 'pnim' && currentUser) {
        page = 'pnim-pnim';
    }
    if ((page === 'pnim-pnim') && !currentUser) {
        page = 'pnim';
