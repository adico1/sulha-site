        אל.innerHTML = '<span class="נורה אדום"></span>מנותק';
    }
    document.getElementById("מצב-זמן").textContent = new Date().toLocaleTimeString('he-IL');
}

async function צפהפנים() {
    document.getElementById("צפיות-כותרת-טקסט").textContent = "צפה פנים - ליבה · פנים · חוץ";
