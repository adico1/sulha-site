            <h3>ממשקים</h3>
            <div id="רשימת-ממשקים">
                <div class="טוען">טוען...</div>
            </div>
            <hr style="border-color:#2a2a4a; margin: 12px 0;">
            <h3>שלשה ספרים</h3>
            <div id="סיכום-ספרים" style="font-size:0.8em; color:#888;"></div>
        </div>

        <div class="צפיות">
            <div class="צפיות-כותרת">
                <span id="צפיות-כותרת-טקסט">ליבה · פנים · חוץ</span>
                <span id="צפיות-עדכון" style="font-size:0.8em; color:#666;"></span>
            </div>
            <div class="צפיות-תוכן" id="צפיות-תוכן">
                <div class="טוען">מתחבר אל הבמה...</div>
            </div>
            <div class="צפיות-רגל">
                <span id="צפיות-סטטוס">ממתין</span>
            </div>
        </div>
    </div>
</div>

<script>
const במה = "http://localhost:8771";
let עדכון_אחרון = null;
let מרווח_צפייה = null;

async function בקש(נתיב) {
    try {
        const ת = await fetch(`${במה}${נתיב}`);
        return await ת.json();
    } catch (e) {
        return { שגיאה: e.message };
    }
}

function הצגJSON(תוכן) {
    return JSON.stringify(תוכן, null, 2);
}

function צפייהHTML(כותרת, תוכן, סוג = "") {
    return `<div class="צפייה ${סוג}">
        <div class="צפייה-כותרת">
            <span>${כותרת}</span>
            <span style="font-size:0.8em;color:#666;">${new Date().toLocaleTimeString('he-IL')}</span>
        </div>
        <div class="צפייה-תוכן">${typeof תוכן === 'string' ? תוכן : הצגJSON(תוכן)}</div>
    </div>`;
}

function עדכןמצב(מחובר) {
    const אל = document.getElementById("מצב-חיבור");
    if (מחובר) {
        אל.innerHTML = '<span class="נורה ירוק"></span>מחובר';
    } else {
        אל.innerHTML = '<span class="נורה אדום"></span>מנותק';
    }
    document.getElementById("מצב-זמן").textContent = new Date().toLocaleTimeString('he-IL');
}

async function צפהפנים() {
    document.getElementById("צפיות-כותרת-טקסט").textContent = "צפה פנים - ליבה · פנים · חוץ";
    const תוכן = document.getElementById("צפיות-תוכן");
    תוכן.innerHTML = '<div class="טוען">צופה...</div>';

    const צפה = await בקש("/api/%D7%A6%D7%A4%D7%94");
    if (צפה.שגיאה) {
        עדכןמצב(false);
        תוכן.innerHTML = צפייהHTML("שגיאה", צפה, "רוגז");
        return;
    }
    עדכןמצב(true);

    let html = '<div class="אזורים">';
    html += `<div class="אזור"><div class="אזור-שם">ליבה</div><div class="אזור-מספר">${צפה.ליבה?.ממשקים || 0}</div><div class="ממשק-מטא">ממשקים</div></div>`;
    html += `<div class="אזור"><div class="אזור-שם">פנים</div><div class="אזור-מספר">${Object.keys(צפה.פנים || {}).length}</div><div class="ממשק-מטא">צופים</div></div>`;
    html += `<div class="אזור"><div class="אזור-שם">חוץ</div><div class="אזור-מספר">${צפה.חוץ?.דומיין ? '✓' : '✗'}</div><div class="ממשק-מטא">${צפה.חוץ?.דומיין || 'לא מוגדר'}</div></div>`;
    html += '</div>';

    // פנים - כל ממשק
    if (צפה.פנים) {
        for (const [שם, מ] of Object.entries(צפה.פנים)) {
            html += צפייהHTML(`ממשק: ${שם}`, מ, מ.מחובר ? '' : 'רוגז');
        }
    }

    // רוגזים ממתינים
    if (צפה.ליבה?.רוגזים_ממתינים > 0) {
        html += צפייהHTML(`רוגזים ממתינים: ${צפה.ליבה.רוגזים_ממתינים}`, "לחץ 'רוגזים' לפרטים", "רוגז");
    }

    תוכן.innerHTML = html;
    עדכןממשקים(צפה.פנים);
    document.getElementById("צפיות-עדכון").textContent = new Date().toLocaleTimeString('he-IL');
}

async function צפהרוגזים() {
    document.getElementById("צפיות-כותרת-טקסט").textContent = "רוגזים ממתינים";
    const תוכן = document.getElementById("צפיות-תוכן");
    const רוגזים = await בקש("/api/%D7%A8%D7%95%D7%92%D7%96%D7%99%D7%9D");
    let html = '';
    if (רוגזים.ממתינים) {
        for (const ר of רוגזים.ממתינים.reverse()) {
            html += צפייהHTML(`${ר.מקור} - ${ר.זמן?.substring(11,19) || ''}`, ר.סיבה, "רוגז");
        }
        html += `<div style="text-align:center;color:#666;margin-top:12px;">סה"כ: ${רוגזים.סהכ}</div>`;
    } else {
        html = צפייהHTML("רוגזים", רוגזים);
    }
    תוכן.innerHTML = html;
}

async function צפהמחולל() {
    document.getElementById("צפיות-כותרת-טקסט").textContent = "מחולל - צופים בנים";
    const תוכן = document.getElementById("צפיות-תוכן");
    const מחולל = await בקש("/api/%D7%9E%D7%97%D7%95%D7%9C%D7%9C");
    let html = '';
    if (מחולל && !מחולל.שגיאה) {
        for (const [שם, בן] of Object.entries(מחולל)) {
            html += צפייהHTML(`בן: ${שם}`, בן, בן.מחובר ? '' : 'רוגז');
        }
    } else {
        html = צפייהHTML("מחולל", מחולל);
    }
    תוכן.innerHTML = html;
}

async function צפהממשק(שם) {
    document.getElementById("צפיות-כותרת-טקסט").textContent = `ממשק: ${שם}`;
    const תוכן = document.getElementById("צפיות-תוכן");

    // סמן פעיל
    document.querySelectorAll('.ממשק-כרטיס').forEach(k => k.classList.remove('פעיל'));
    const כרטיס = document.querySelector(`[data-ממשק="${שם}"]`);
    if (כרטיס) כרטיס.classList.add('פעיל');

    const מצב = await בקש(`/api/%D7%9E%D7%9E%D7%A9%D7%A7/${encodeURIComponent(שם)}`);
    let html = צפייהHTML(`צפה פנים: ${שם}`, מצב, מצב.מחובר ? '' : 'רוגז');

    // עשה פעולות ידועות
    if (מצב.שפה?.פעולות_ידועות) {
        for (const פ of מצב.שפה.פעולות_ידועות) {
            const ת = await בקש(`/api/%D7%9E%D7%9E%D7%A9%D7%A7/${encodeURIComponent(שם)}/${encodeURIComponent(פ)}`);
            html += צפייהHTML(`עשה: ${שם}/${פ}`, ת);
        }
    }

    תוכן.innerHTML = html;
}

function עדכןממשקים(פנים) {
    const אל = document.getElementById("רשימת-ממשקים");
    if (!פנים) return;
    let html = '';
    for (const [שם, מ] of Object.entries(פנים)) {
        const נורה = מ.מחובר ? 'ירוק' : 'אדום';
        html += `<div class="ממשק-כרטיס" data-ממשק="${שם}" onclick="צפהממשק('${שם}')">
            <div class="ממשק-שם"><span class="נורה ${נורה}"></span>${שם}</div>
            <div class="ממשק-מטא">צפיות: ${מ.צפיות || 0} | רוגזים: ${מ.רוגזים || 0}</div>
        </div>`;
    }
    אל.innerHTML = html;
}

// צפייה מחזורית - כל 10 שניות
async function לולאת_צפייה() {
    await צפהפנים();
    מרווח_צפייה = setInterval(צפהפנים, 10000);
}

// התחל
לולאת_צפייה();
document.getElementById("צפיות-סטטוס").textContent = "צפייה פעילה - כל 10 שניות";
</script>

</body>
</html>


